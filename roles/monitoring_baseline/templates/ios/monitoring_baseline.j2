! ==========================================================
! Monitoring baseline generated by Ansible from NetBox data
! Device: {{ inventory_hostname }}
! ==========================================================
{% set ctx_raw = config_context | default({}) %}
{% if ctx_raw is mapping %}
{% set ctx = ctx_raw %}
{% elif ctx_raw is sequence and (ctx_raw | length) > 0 and (ctx_raw | first) is mapping %}
{% set ctx = ctx_raw | first %}
{% else %}
{% set ctx = {} %}
{% endif %}
{% set site_name = sites[0].name if sites is defined and sites is sequence and (sites | length) > 0 and sites[0] is mapping else (sites[0] if sites is defined and sites is sequence and (sites | length) > 0 else 'Unknown') %}
{% set rack_name = racks[0] if racks is defined and racks is sequence and (racks | length) > 0 else '' %}
{% set inventory_location = site_name ~ (' / ' ~ rack_name if rack_name else '') %}
{% set configured_location = monitoring_snmp_location | default('') | trim %}
{% set snmp_location = inventory_location if configured_location in ['', 'Unknown'] else configured_location %}
service timestamps log datetime msec localtime show-timezone
service timestamps debug datetime msec localtime show-timezone

{% set ctx_ntp_raw = ctx.get('ntp_servers') | default([]) %}
{% set ctx_ntp_servers = ctx_ntp_raw if ctx_ntp_raw is sequence and ctx_ntp_raw is not string else [] %}
{% set configured_ntp_servers = monitoring_ntp_servers | default([]) %}
{% set ntp_source = configured_ntp_servers if configured_ntp_servers | length > 0 else ctx_ntp_servers %}
{% set ntp_servers = ntp_source | reject('equalto', '') | list %}
{% for ntp_server in ntp_servers %}
ntp server {{ ntp_server }}
{% endfor %}

{% set ctx_syslog_raw = ctx.get('syslog_servers') | default([]) %}
{% set ctx_syslog_servers = ctx_syslog_raw if ctx_syslog_raw is sequence and ctx_syslog_raw is not string else [] %}
{% set configured_syslog_servers = monitoring_syslog_servers | default([]) %}
{% set syslog_source = configured_syslog_servers if configured_syslog_servers | length > 0 else ctx_syslog_servers %}
{% set polling_servers = monitoring_zabbix_servers | default([]) | reject('equalto', '') | list %}
{% set syslog_servers = (syslog_source + polling_servers) | reject('equalto', '') | unique | list %}
{% for syslog_server in syslog_servers %}
logging host {{ syslog_server }}
{% endfor %}
{% if syslog_servers | length > 0 %}
logging trap {{ monitoring_logging_trap_level }}
logging source-interface {{ monitoring_syslog_source_interface | default('Vlan1') }}
{% endif %}

{% if monitoring_enable_lldp | bool %}
lldp run
{% endif %}
{% if monitoring_enable_cdp | bool %}
cdp run
{% endif %}

{% set snmp_acl_part = ' ' ~ monitoring_snmp_acl_name if polling_servers | length > 0 else '' %}
{% set snmpv3_access_part = ' access ' ~ monitoring_snmp_acl_name if polling_servers | length > 0 else '' %}
{% if polling_servers | length > 0 %}
ip access-list standard {{ monitoring_snmp_acl_name }}
{% for polling_server in polling_servers %}
 permit {{ polling_server }}
{% endfor %}
 deny any log
{% endif %}

{% if monitoring_snmp_version == 'v2c' and monitoring_snmp_community | length > 0 %}
snmp-server community {{ monitoring_snmp_community }} RO{{ snmp_acl_part }}
{% elif monitoring_snmp_version == 'v3' and monitoring_snmpv3_user | length > 0 and monitoring_snmpv3_auth_pass | length > 0 and monitoring_snmpv3_priv_pass | length > 0 %}
snmp-server group {{ monitoring_snmpv3_group }} v3 priv{{ snmpv3_access_part }}
snmp-server user {{ monitoring_snmpv3_user }} {{ monitoring_snmpv3_group }} v3 auth sha {{ monitoring_snmpv3_auth_pass }} priv aes 128 {{ monitoring_snmpv3_priv_pass }}
{% endif %}
snmp-server contact {{ monitoring_snmp_contact }}
snmp-server location {{ snmp_location }}
snmp-server enable traps

{% if monitoring_apply_interface_descriptions | bool and interfaces is defined %}
! ==========================================================
! Interface descriptions sourced from NetBox
! ==========================================================
{% set nb_interfaces = interfaces.values() if interfaces is mapping else (interfaces | default([])) %}
{% for item in nb_interfaces %}
{% set intf = item.value | default(item) if item is mapping else item %}
{% if intf is mapping %}
{% set intf_name = intf.name | default(intf.display | default('')) %}
{% set intf_description = intf.description | default('') %}
{% if intf_name and intf_description %}
interface {{ intf_name }}
 description {{ intf_description }}
{% endif %}
{% endif %}
{% endfor %}
{% endif %}
